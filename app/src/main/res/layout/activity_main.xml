<?xml version="1.0" encoding="utf-8"?>
<!-- ZArchiver-style layout: ConstraintLayout + panel + FAB -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content = ConstraintLayout like ZArchiver's dlg_main_list -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_file_list">

        <!-- Custom toolbar area -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="?attr/actionBarSize"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/bg_toolbar"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/btnDrawer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_menu_more"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/ui_icon_tint" />

            <ImageButton
                android:id="@+id/btnRoot"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_menu_compass"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/ui_base"
                android:contentDescription="回到根目录" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="UsefulUnpack"
                android:textSize="18sp"
                android:textColor="@color/ui_icon_tint"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCLI"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text=">_"
                android:textSize="16sp"
                android:textColor="@color/ui_icon_tint"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <!-- Path breadcrumb -->
        <LinearLayout
            android:id="@+id/pathBar"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/bg_pathbar"
            android:paddingStart="6dp"
            android:paddingEnd="4dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/btnUp"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/arrow_up_float"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/ui_icon_tint" />

            <TextView
                android:id="@+id/tvPath"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="/"
                android:textSize="11sp"
                android:textColor="#b0b0b0"
                android:singleLine="true"
                android:ellipsize="start" />

            <TextView
                android:id="@+id/tvCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:textColor="@color/text_file_msg"
                android:paddingEnd="6dp" />
        </LinearLayout>

        <!-- File panel (main area) -->
        <FrameLayout
            android:id="@+id/panel"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/bg_file_list"
            app:layout_constraintTop_toBottomOf="@id/pathBar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ListView
                android:id="@+id/listFiles"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="#1a1a1a"
                android:dividerHeight="1dp"
                android:listSelector="#40ffffff"
                android:cacheColorHint="@color/bg_file_list"
                android:fastScrollEnabled="true"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text=""
                android:textSize="14sp"
                android:textColor="@color/text_file_msg"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Bottom bar (selected file) -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/bg_toolbar"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvSelected"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/ui_icon_tint" />

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:visibility="gone"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnExtract"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="解压"
                android:textSize="13sp"
                android:backgroundTint="@color/ui_base" />
        </LinearLayout>

        <!-- FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabExtract"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:src="@android:drawable/ic_menu_upload"
            android:visibility="gone"
            android:backgroundTint="@color/ui_base"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Drawer: bookmarks -->
    <LinearLayout
        android:id="@+id/drawerContent"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#ff252525">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:text="快捷路径"
            android:textSize="14sp"
            android:textColor="@color/ui_base"
            android:textStyle="bold"
            android:background="#ff222222" />

        <ListView
            android:id="@+id/listBookmarks"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="#ff222222"
            android:dividerHeight="1dp" />

        <TextView
            android:id="@+id/btnAddBookmark"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="+ 添加当前路径"
            android:textSize="13sp"
            android:textColor="@color/ui_base"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
